# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=your-supabase-url
# Service role (secret) key — required for server-side admin tasks (e.g. deleting auth users on account deletion)
SUPABASE_KEY=your-supabase-key

# JWT (for custom tokens if needed)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Cloud Run: set JSON list; optional regex for Vercel *.vercel.app)
# CORS_ORIGINS=["http://localhost:3000","https://dotsmove.com","https://www.dotsmove.com"]
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# App
DEBUG=true
AUTO_APPROVE_RSVPS=false